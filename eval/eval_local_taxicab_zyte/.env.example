# eval_local_taxicab_zyte — environment template
# Copy to .env (which is gitignored) and fill in keys.

# Anthropic — required for the Sonnet extractor + Opus judge
ANTHROPIC_API_KEY=

# Zyte — required only for scripts/rerun_rases_zyte.py
# Sign up at https://www.zyte.com/zyte-api/  → Account → API key
ZYTE_API_KEY=

# Local Chrome over CDP — required only for the local-Chrome tier
# Launch visible Chrome with: google-chrome --remote-debugging-port=9222
CDP_URL=http://localhost:9222

# Taxicab harvester — defaults baked into eval/browser-use/runtime/taxicab_reharvest.py
# Override only if pointing at a non-default harvester.
# TAXICAB_HARVESTER_URL=http://harvester-load-balancer-366186003.us-east-1.elb.amazonaws.com

# Extractor + judge model overrides (optional)
# EXTRACTOR_MODEL=claude-sonnet-4-5
# JUDGE_MODEL=claude-opus-4-5
