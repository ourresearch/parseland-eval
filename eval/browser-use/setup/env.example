# env.example — copy to eval/.env on BUX before running smoke.sh / parity_50.sh / run_10k_on_bux.sh
# DO NOT commit a real .env. The deploy script (02-deploy.sh) scp's your local eval/.env to BUX.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic (Tier 1 cached-HTML extraction and Tier 2 live-fetch agent reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# Browser Use Cloud (Tier 2 via Browser Harness sessions; Starter tier = 50 concurrent)
# If you don't have one yet, see setup/01-provision.md step 6 for AI-agent self-registration.
BROWSER_USE_API_KEY=bu_...

# Chrome DevTools Protocol URL for Tier 2.
# On BUX: this is the wss:// URL exposed by the browser-harness systemd service.
# Locally (for testing): http://localhost:9222 after `chrome --remote-debugging-port=9222`
CDP_URL=wss://<browser-harness-host>:<port>

# Telegram bot — for batch-1 scoreboard ping and /go gate handoff
TELEGRAM_BOT_TOKEN=<from @BotFather>
TELEGRAM_CHAT_ID=<private channel id; get via getUpdates after sending a test message>

# Taxicab harvester URL — drives Tier 1.5 (POST /taxicab to refresh stale cache).
# Production load balancer (us-east-1):
TAXICAB_HARVESTER_URL=http://harvester-load-balancer-366186003.us-east-1.elb.amazonaws.com

# ─── Optional ─────────────────────────────────────────────────────────────────

# Only if Starter-tier residential proxies prove insufficient for specific publishers.
# Default is NOT to use Zyte (Browser Use Cloud's residential proxy is sufficient
# per memory entry — Browser Harness ships with 195+ country proxies).
# ZYTE_API_KEY=

# Override the OpenAI Codex model used during cross-AI review (default: from ~/.codex/config.toml).
# Not used by BUX runtime; only relevant for re-running Codex reviews locally.
# CODEX_MODEL=gpt-5.5
